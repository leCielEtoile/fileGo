# ==============================================
# Docker Compose 環境変数
# ==============================================
# デプロイ時はこのファイルを .env にコピーして編集してください
#   cp .env.example .env
#
# 【重要】秘密情報（bot_token / client_secret）の「値」は環境変数に入れません。
# 環境変数は docker inspect・プロセス一覧・ログ経由で漏れるためです。
# 設定方法は次の2通りです。
#   1) config.yaml の auth.provider に記述する（既定）
#   2) ファイルとして渡し、FILEGO_*_FILE でそのパスを指定する（Docker secrets 等）
#
# アプリの設定は FILEGO_ 接頭辞付きの環境変数で上書きできます（config.yaml より優先）。
# 接頭辞なしの旧名（SERVER_PORT 等）は読み込まれません。

# ----------------------------------------------
# Docker / ホスト側の設定（アプリの設定ではない）
# ----------------------------------------------

# Dockerイメージタグ（latest / v0.2.0 / 0.2 など）
IMAGE_TAG=latest

# ホスト側の公開ポート
HOST_PORT=8080

# タイムゾーン（Goランタイムが解釈する標準の変数のため接頭辞は付かない）
TZ=Asia/Tokyo

# 実行UID/GID。bindマウントへ書き込むファイルの所有者になる。
# ホストユーザーに合わせると sudo なしで管理・削除できる。
#
# Docker Compose は id -u を自動実行できない（.env はコマンド置換に非対応）ため、
# 自分の値で生成してください。編集は不要です。
#   printf 'PUID=%s\nPGID=%s\n' "$(id -u)" "$(id -g)" > .env
#
# 未設定ならイメージ既定の 65532 で動作します（その場合ホスト側ディレクトリも
# 65532 所有にする必要があります）。
PUID=1000
PGID=1000

# ----------------------------------------------
# アプリ設定（FILEGO_ 接頭辞。config.yaml より優先される）
# 省略した項目は config.yaml、それも無ければ既定値が使われる。
# ----------------------------------------------

# ログレベル（debug / info / warn / error）。既定 info。
# debug にすると /health・/static のアクセスログや認証の詳細も出力される。
FILEGO_LOG_LEVEL=info

# --- サーバー ---
# FILEGO_SERVER_PORT=8080
# FILEGO_SERVER_SERVICE_NAME=Discord File Server
# FILEGO_SERVER_BEHIND_PROXY=true
# FILEGO_SERVER_SECURE_COOKIE=true          # HTTPSでない環境では false
# FILEGO_SERVER_TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16

# --- データベース ---
# ※ Dockerイメージは FILEGO_DATABASE_PATH=/app/config/fileserver.db を既定で設定済み
# FILEGO_DATABASE_MAX_CONNECTIONS=10

# --- ストレージ ---
# ※ Dockerイメージは FILEGO_STORAGE_UPLOAD_PATH=/app/data/uploads を既定で設定済み
# FILEGO_STORAGE_MAX_FILE_SIZE=104857600          # 100MB
# FILEGO_STORAGE_CHUNK_UPLOAD_ENABLED=true
# FILEGO_STORAGE_CHUNK_SIZE=20971520              # 20MB
# FILEGO_STORAGE_MAX_CHUNK_FILE_SIZE=536870912000 # 500GB
# FILEGO_STORAGE_MAX_CONCURRENT_UPLOADS=3
# FILEGO_STORAGE_UPLOAD_SESSION_TTL=48h
# FILEGO_STORAGE_CLEANUP_INTERVAL=1h
# FILEGO_STORAGE_ADMIN_ROLE_ID=123456789012345678

# ----------------------------------------------
# 秘密情報をファイルで渡す場合（任意。Docker secrets / K8s Secret 向け）
# ----------------------------------------------
# 値ではなく「ファイルのパス」を指定する。docker-compose.yml の secrets も有効化すること。
# FILEGO_BOT_TOKEN_FILE=/run/secrets/bot_token
# FILEGO_CLIENT_SECRET_FILE=/run/secrets/client_secret
