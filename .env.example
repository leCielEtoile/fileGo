# ==============================================
# Docker Compose 環境変数
# ==============================================
# デプロイ時はこのファイルを .env にコピーして編集してください
# cp .env.example .env
#
# 【重要】認証情報（Discordのbot_token/client_secret、OIDCのissuer等）は
# 環境変数では設定できません。config.yaml の auth.provider に記述してください。
# 環境変数で上書きできるのは server / database / storage の一部のみです。

# ----------------------------------------------
# Docker設定
# ----------------------------------------------

# Dockerイメージタグ（latest / v1.0.0 / main-abc1234 など）
IMAGE_TAG=latest

# ホスト側のポート番号
HOST_PORT=8080

# タイムゾーン
TZ=Asia/Tokyo

# ログレベル（debug / info / warn / error）。既定 info。
# debug にすると /health・/static のアクセスログや認証の詳細も出力される。
LOG_LEVEL=info

# ----------------------------------------------
# 実行ユーザー（bindマウント上のファイル所有者）
# ----------------------------------------------
# コンテナが ./config ./data に書き込むファイルの所有者(UID:GID)を決める。
# ホストユーザーに合わせると、生成ファイルをそのユーザーがそのまま
# 管理・削除できる（rootが必要になる問題を回避）。
#   確認: id -u / id -g
# 未指定の場合はイメージ既定の非rootユーザー(65532)で動作する（後方互換）。
# 初回起動前にホスト側ディレクトリの所有者も合わせておくこと:
#   mkdir -p config data && sudo chown -R "$(id -u):$(id -g)" config data
PUID=1000
PGID=1000

# ----------------------------------------------
# サーバー設定（任意・config.yamlを上書き）
# ----------------------------------------------
SERVER_PORT=8080
SERVER_SERVICE_NAME=Discord File Server
SERVER_BEHIND_PROXY=true
# カンマ区切りで複数指定可能
SERVER_TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16

# ----------------------------------------------
# データベース設定（任意・config.yamlを上書き）
# ----------------------------------------------
DATABASE_PATH=/app/config/fileserver.db
DATABASE_MAX_CONNECTIONS=10

# ----------------------------------------------
# ストレージ設定（任意・config.yamlを上書き）
# ----------------------------------------------
STORAGE_UPLOAD_PATH=/app/data/uploads
STORAGE_MAX_FILE_SIZE=104857600
STORAGE_CHUNK_SIZE=20971520
STORAGE_MAX_CHUNK_FILE_SIZE=536870912000
STORAGE_MAX_CONCURRENT_UPLOADS=3
STORAGE_CHUNK_UPLOAD_ENABLED=true
STORAGE_UPLOAD_SESSION_TTL=48h
STORAGE_CLEANUP_INTERVAL=1h
STORAGE_ADMIN_ROLE_ID=123456789012345678

# ----------------------------------------------
# 設定例
# ----------------------------------------------
# 開発環境:
#   IMAGE_TAG=latest
#   HOST_PORT=8080
#   SERVER_PORT=8080
#
# 本番環境:
#   IMAGE_TAG=v1.0.0
#   HOST_PORT=80
#   SERVER_BEHIND_PROXY=true
#
# ファイルサイズ上限の変更:
#   STORAGE_MAX_FILE_SIZE=209715200        # 200MB
#   STORAGE_MAX_CHUNK_FILE_SIZE=1073741824000  # 1TB
